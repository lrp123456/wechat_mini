<view class="page-container">
  <!-- 顶部标题栏 -->
  <view class="header">
    <view class="header-content">
      <view class="avatar">
        <image src="https://api.dicebear.com/7.x/avataaars/svg?seed=workflow" mode="aspectFill" />
      </view>
      <text class="header-title">工作流日志</text>
    </view>
  </view>

  <scroll-view class="scrollarea" scroll-y type="list">
    <view class="container">
      <!-- 统计概览 -->
      <view class="stats-row">
        <view class="stat-card">
          <text class="stat-number">{{stats.total}}</text>
          <text class="stat-label">总记录</text>
        </view>
        <view class="stat-card success">
          <text class="stat-number">{{stats.success}}</text>
          <text class="stat-label">成功</text>
        </view>
        <view class="stat-card failed">
          <text class="stat-number">{{stats.failed}}</text>
          <text class="stat-label">失败</text>
        </view>
      </view>

      <!-- 筛选标签 -->
      <view class="filter-tabs">
        <view class="tab {{activeFilter === 'all' ? 'active' : ''}}" bindtap="filterLogs" data-filter="all">
          <text>全部</text>
        </view>
        <view class="tab {{activeFilter === 'crawler' ? 'active' : ''}}" bindtap="filterLogs" data-filter="crawler">
          <text>采集</text>
        </view>
        <view class="tab {{activeFilter === 'material-update' ? 'active' : ''}}" bindtap="filterLogs" data-filter="material-update">
          <text>素材</text>
        </view>
        <view class="tab {{activeFilter === 'video-generate' ? 'active' : ''}}" bindtap="filterLogs" data-filter="video-generate">
          <text>视频</text>
        </view>
        <view class="tab {{activeFilter === 'upload' ? 'active' : ''}}" bindtap="filterLogs" data-filter="upload">
          <text>上传</text>
        </view>
      </view>

      <!-- 日志列表 -->
      <view class="log-list" wx:if="{{filteredLogs.length > 0}}">
        <view class="log-item {{item.status}}" wx:for="{{filteredLogs}}" wx:key="id">
          <view class="log-timeline">
            <view class="timeline-dot {{item.status}}"></view>
            <view class="timeline-line" wx:if="{{index < filteredLogs.length - 1}}"></view>
          </view>
          <view class="log-content">
            <view class="log-header">
              <view class="log-type-badge {{item.type}}">
                <text>{{item.typeName}}</text>
              </view>
              <view class="log-status-badge {{item.status}}">
                <text>{{item.statusName}}</text>
              </view>
              <text class="log-time">{{item.timeStr}}</text>
            </view>
            <text class="log-message">{{item.message}}</text>
            <view class="log-details" wx:if="{{item.details}}">
              <text class="detail-text">{{item.detailText}}</text>
            </view>
          </view>
        </view>
      </view>

      <!-- 空状态 -->
      <view class="empty-state" wx:if="{{filteredLogs.length === 0}}">
        <view class="empty-icon">📋</view>
        <text>暂无日志记录</text>
      </view>

      <!-- 清空按钮 -->
      <view class="clear-action" wx:if="{{filteredLogs.length > 0}}">
        <view class="btn btn-secondary" bindtap="clearLogs">
          <text>清空日志</text>
        </view>
      </view>
    </view>
  </scroll-view>
</view>
