<view class="page-container">
  <!-- 顶部标题栏 -->
  <view class="header">
    <view class="header-content">
      <view class="avatar">
        <image src="https://api.dicebear.com/7.x/avataaars/svg?seed=workflow" mode="aspectFill" />
      </view>
      <text class="header-title">素材库</text>
    </view>
  </view>

  <scroll-view class="scrollarea" scroll-y type="list">
    <view class="container">
      <!-- 分类标签 -->
      <view class="filter-tabs">
        <view class="tab {{activeTab === 'all' ? 'active' : ''}}" bindtap="switchTab" data-tab="all">
          <text>全部</text>
        </view>
        <view class="tab {{activeTab === 'image' ? 'active' : ''}}" bindtap="switchTab" data-tab="image">
          <text>图片</text>
        </view>
        <view class="tab {{activeTab === 'video' ? 'active' : ''}}" bindtap="switchTab" data-tab="video">
          <text>视频</text>
        </view>
        <view class="tab {{activeTab === 'audio' ? 'active' : ''}}" bindtap="switchTab" data-tab="audio">
          <text>音频</text>
        </view>
      </view>

      <!-- 素材网格 -->
      <view class="material-grid" wx:if="{{filteredMaterials.length > 0}}">
        <view class="material-item" wx:for="{{filteredMaterials}}" wx:key="id">
          <view class="material-preview">
            <image wx:if="{{item.type === 'image' || item.type === 'video'}}" class="material-image" src="{{item.url}}" mode="aspectFill" lazy-load />
            <view wx:if="{{item.type === 'audio'}}" class="audio-placeholder">
              <text class="audio-icon">🎵</text>
            </view>
            <view class="material-type-badge {{item.type}}">
              <text>{{item.type === 'image' ? '图' : item.type === 'video' ? '视' : '音'}}</text>
            </view>
            <view class="material-status {{item.status}}">
              <text>{{item.status === 'available' ? '可用' : item.status === 'used' ? '已用' : '处理中'}}</text>
            </view>
          </view>
          <view class="material-info">
            <text class="material-title">{{item.title}}</text>
            <view class="material-meta">
              <text class="material-source">{{item.source}}</text>
              <view class="material-tags">
                <text class="tag" wx:for="{{item.tags}}" wx:for-item="tag" wx:key="*this">{{tag}}</text>
              </view>
            </view>
          </view>
          <view class="material-actions">
            <view class="action-btn delete" bindtap="deleteMaterial" data-id="{{item.id}}">
              <text>删除</text>
            </view>
          </view>
        </view>
      </view>

      <!-- 空状态 -->
      <view class="empty-state" wx:if="{{filteredMaterials.length === 0}}">
        <view class="empty-icon">📁</view>
        <text>暂无素材</text>
        <view class="btn btn-primary" style="margin-top: 32rpx; width: 240rpx;" bindtap="goToCrawler">
          去采集素材
        </view>
      </view>
    </view>
  </scroll-view>
</view>
