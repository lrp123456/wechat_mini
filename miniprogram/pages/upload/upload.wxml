<view class="page-container">
  <!-- 顶部标题栏 -->
  <view class="header">
    <view class="header-content">
      <view class="avatar">
        <image src="https://api.dicebear.com/7.x/avataaars/svg?seed=workflow" mode="aspectFill" />
      </view>
      <text class="header-title">自动上传</text>
    </view>
  </view>

  <scroll-view class="scrollarea" scroll-y type="list">
    <view class="container">
      <!-- 选择视频 -->
      <view class="card video-select" wx:if="{{!selectedVideo}}">
        <view class="section-header">
          <view class="section-icon icon-video"></view>
          <text class="section-title">选择视频</text>
        </view>
        <view class="video-list">
          <view class="video-item" wx:for="{{videoTasks}}" wx:key="id" bindtap="selectVideo" data-id="{{item.id}}">
            <view class="video-preview">
              <image src="{{item.outputUrl || 'https://picsum.photos/400/300?random=1'}}" mode="aspectFill" />
              <view class="video-type-badge {{item.type}}">
                <text>{{item.type === 'no-narration' ? '无解说' : '带解说'}}</text>
              </view>
            </view>
            <view class="video-info">
              <text class="video-style">{{item.style}}</text>
              <text class="video-time">{{item.createdAtStr}}</text>
            </view>
          </view>
        </view>
        <view class="empty-state" wx:if="{{videoTasks.length === 0}}">
          <view class="empty-icon">🎬</view>
          <text>没有可上传的视频</text>
          <view class="btn btn-primary" style="margin-top: 32rpx; width: 240rpx;" bindtap="goToVideo">
            去生成视频
          </view>
        </view>
      </view>

      <!-- 已选视频 -->
      <view class="card selected-video" wx:if="{{selectedVideo}}">
        <view class="section-header">
          <view class="section-icon icon-video"></view>
          <text class="section-title">已选视频</text>
          <view class="change-btn" bindtap="changeVideo">
            <text>更换</text>
          </view>
        </view>
        <view class="video-preview-large">
          <image src="{{selectedVideo.outputUrl}}" mode="aspectFill" />
          <view class="video-type-badge {{selectedVideo.type}}">
            <text>{{selectedVideo.type === 'no-narration' ? '无解说' : '带解说'}}</text>
          </view>
        </view>
        <view class="video-detail">
          <text class="detail-style">{{selectedVideo.style}}</text>
          <text class="detail-time">生成于 {{selectedVideo.createdAtStr}}</text>
        </view>
      </view>

      <!-- 平台选择 -->
      <view class="card platform-section" wx:if="{{selectedVideo}}">
        <view class="section-header">
          <view class="section-icon icon-platform"></view>
          <text class="section-title">选择平台</text>
        </view>
        <view class="platform-list">
          <view class="platform-item {{item.enabled ? 'enabled' : ''}} {{item.selected ? 'selected' : ''}}" wx:for="{{platforms}}" wx:key="id" bindtap="togglePlatform" data-id="{{item.id}}">
            <view class="platform-icon {{item.id}}">
              <text>{{item.icon}}</text>
            </view>
            <view class="platform-info">
              <text class="platform-name">{{item.name}}</text>
              <text class="platform-status">{{item.enabled ? '已启用' : '未启用'}}</text>
            </view>
            <view class="platform-check {{item.selected ? 'checked' : ''}}">
              <text wx:if="{{item.selected}}">✓</text>
            </view>
          </view>
        </view>
      </view>

      <!-- 上传配置 -->
      <view class="card config-section" wx:if="{{selectedVideo && selectedPlatforms.length > 0}}">
        <view class="section-header">
          <view class="section-icon icon-config"></view>
          <text class="section-title">上传配置</text>
        </view>
        <view class="config-item">
          <text class="config-label">视频标题</text>
          <input class="config-input" placeholder="输入视频标题" value="{{uploadTitle}}" bindinput="onTitleInput" />
        </view>
        <view class="config-item">
          <text class="config-label">视频描述</text>
          <textarea class="config-textarea" placeholder="输入视频描述" value="{{uploadDesc}}" bindinput="onDescInput" />
        </view>
        <view class="config-item">
          <text class="config-label">标签</text>
          <input class="config-input" placeholder="输入标签，用空格分隔" value="{{uploadTags}}" bindinput="onTagsInput" />
        </view>
      </view>

      <!-- 开始上传 -->
      <view class="upload-action" wx:if="{{selectedVideo && selectedPlatforms.length > 0}}">
        <view class="btn btn-primary {{uploading ? 'btn-loading' : ''}}" bindtap="startUpload">
          <text wx:if="{{!uploading}}">开始上传 ({{selectedPlatforms.length}}个平台)</text>
          <view wx:else class="loading-dots">
            <view class="dot"></view>
            <view class="dot"></view>
            <view class="dot"></view>
          </view>
        </view>
      </view>

      <!-- 上传任务列表 -->
      <view class="card upload-tasks" wx:if="{{uploadTasks.length > 0}}">
        <view class="section-header">
          <view class="section-icon icon-tasks"></view>
          <text class="section-title">上传记录</text>
        </view>
        <view class="upload-list">
          <view class="upload-item" wx:for="{{uploadTasks}}" wx:key="id">
            <view class="upload-header">
              <text class="upload-title">{{item.title}}</text>
              <view class="upload-status {{item.status}}">
                <text>{{item.status === 'completed' ? '已完成' : item.status === 'uploading' ? '上传中' : item.status === 'failed' ? '失败' : '待处理'}}</text>
              </view>
            </view>
            <view class="upload-platforms">
              <view class="platform-tag {{p.status}}" wx:for="{{item.platformList}}" wx:for-item="p" wx:key="id">
                <text>{{p.name}}</text>
                <view class="platform-progress" wx:if="{{p.status === 'uploading'}}">
                  <view class="progress-fill" style="width: {{p.progress}}%"></view>
                </view>
              </view>
            </view>
          </view>
        </view>
      </view>
    </view>
  </scroll-view>
</view>
