<view class="page-container">
  <!-- 顶部标题栏 -->
  <view class="header">
    <view class="header-content">
      <view class="avatar">
        <image src="https://api.dicebear.com/7.x/avataaars/svg?seed=workflow" mode="aspectFill" />
      </view>
      <text class="header-title">操作面板</text>
    </view>
  </view>

  <scroll-view class="scrollarea" scroll-y type="list">
    <view class="container">
      <!-- Banner区 -->
      <view class="banner">
        <view class="banner-title">视频工作流</view>
        <view class="banner-subtitle">Video Workflow System</view>
        <view class="banner-decoration">
          <view class="tree tree-1"></view>
          <view class="tree tree-2"></view>
          <view class="tree tree-3"></view>
          <view class="tree tree-4"></view>
          <view class="tree tree-5"></view>
          <view class="ground"></view>
        </view>
      </view>

      <!-- 统计卡片 -->
      <view class="stats-row">
        <view class="stat-card">
          <text class="stat-number">{{stats.totalMaterials}}</text>
          <text class="stat-label">总素材数</text>
        </view>
        <view class="stat-card">
          <text class="stat-number">{{stats.availableMaterials}}</text>
          <text class="stat-label">可用素材</text>
        </view>
        <view class="stat-card">
          <text class="stat-number">{{stats.audioMaterials}}</text>
          <text class="stat-label">音频素材</text>
        </view>
      </view>

      <!-- 素材更新区 -->
      <view class="card action-section">
        <view class="section-header">
          <view class="section-icon icon-update"></view>
          <text class="section-title">素材更新</text>
        </view>
        <view class="picker-wrapper">
          <picker mode="selector" range="{{platforms}}" range-key="name" value="{{selectedPlatformIndex}}" bindchange="onPlatformChange">
            <view class="picker-value">
              <text class="picker-placeholder" wx:if="{{!selectedPlatform}}">请选择素材更新平台</text>
              <text class="picker-text" wx:else>{{selectedPlatform}}</text>
              <view class="picker-arrow">▼</view>
            </view>
          </picker>
        </view>
        <view class="btn btn-accent {{updating ? 'btn-loading' : ''}}" bindtap="onUpdateMaterial">
          <text wx:if="{{!updating}}">更新</text>
          <view wx:else class="loading-dots">
            <view class="dot"></view>
            <view class="dot"></view>
            <view class="dot"></view>
          </view>
        </view>
      </view>

      <!-- 视频生成区 -->
      <view class="card action-section">
        <view class="section-header">
          <view class="section-icon icon-video"></view>
          <text class="section-title">视频生成</text>
        </view>
        <view class="picker-wrapper">
          <picker mode="selector" range="{{videoStyles}}" range-key="name" value="{{selectedStyleIndex}}" bindchange="onStyleChange">
            <view class="picker-value">
              <text class="picker-placeholder" wx:if="{{!selectedStyle}}">请选择要生成的视频风格</text>
              <text class="picker-text" wx:else>{{selectedStyle}}</text>
              <view class="picker-arrow">▼</view>
            </view>
          </picker>
        </view>
        <view class="btn btn-primary {{generating ? 'btn-loading' : ''}}" bindtap="onGenerateVideo" data-type="no-narration">
          <text wx:if="{{!generating}}">生成无解说视频</text>
          <view wx:else class="loading-dots">
            <view class="dot"></view>
            <view class="dot"></view>
            <view class="dot"></view>
          </view>
        </view>
        <view class="btn btn-accent {{generating ? 'btn-loading' : ''}}" bindtap="onGenerateVideo" data-type="with-narration" style="margin-top: 20rpx;">
          <text wx:if="{{!generating}}">生成带解说视频</text>
          <view wx:else class="loading-dots">
            <view class="dot"></view>
            <view class="dot"></view>
            <view class="dot"></view>
          </view>
        </view>
      </view>

      <!-- 快捷入口 -->
      <view class="card quick-actions">
        <view class="section-header">
          <view class="section-icon icon-quick"></view>
          <text class="section-title">快捷入口</text>
        </view>
        <view class="quick-grid">
          <view class="quick-item" bindtap="navigateTo" data-page="crawler">
            <view class="quick-icon icon-crawler"></view>
            <text class="quick-label">Pinterest采集</text>
          </view>
          <view class="quick-item" bindtap="navigateTo" data-page="material">
            <view class="quick-icon icon-material"></view>
            <text class="quick-label">素材库</text>
          </view>
          <view class="quick-item" bindtap="navigateTo" data-page="video">
            <view class="quick-icon icon-video-gen"></view>
            <text class="quick-label">视频管理</text>
          </view>
          <view class="quick-item" bindtap="navigateTo" data-page="upload">
            <view class="quick-icon icon-upload"></view>
            <text class="quick-label">自动上传</text>
          </view>
        </view>
      </view>
    </view>
  </scroll-view>
</view>
