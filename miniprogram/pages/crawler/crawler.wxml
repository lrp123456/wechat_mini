<view class="page-container">
  <!-- 顶部标题栏 -->
  <view class="header">
    <view class="header-content">
      <view class="avatar">
        <image src="https://api.dicebear.com/7.x/avataaars/svg?seed=workflow" mode="aspectFill" />
      </view>
      <text class="header-title">pinterest采集器</text>
    </view>
  </view>

  <scroll-view class="scrollarea" scroll-y type="list">
    <view class="container">
      <!-- 输入区 -->
      <view class="card input-section">
        <view class="input-row">
          <view class="input-group">
            <text class="input-label">查询词</text>
            <input class="input-field" placeholder="请输入查询词" value="{{keyword}}" bindinput="onKeywordInput" />
            <view class="input-icon">✎</view>
          </view>
          <view class="input-group">
            <text class="input-label">爬取数量</text>
            <input class="input-field" type="number" placeholder="请输入爬取数量" value="{{count}}" bindinput="onCountInput" />
          </view>
        </view>

        <!-- 筛选条件 -->
        <view class="filter-section">
          <text class="filter-label">筛选条件</text>
          <view class="filter-buttons">
            <view class="filter-btn {{filter === 'like' ? 'active' : ''}}" bindtap="onFilterChange" data-filter="like">
              <text>like</text>
            </view>
            <view class="filter-btn {{filter === 'save' ? 'active' : ''}}" bindtap="onFilterChange" data-filter="save">
              <text>save</text>
            </view>
            <view class="filter-btn {{filter === 'comments' ? 'active' : ''}}" bindtap="onFilterChange" data-filter="comments">
              <text>comments</text>
            </view>
          </view>
        </view>

        <!-- 提交按钮 -->
        <view class="btn btn-submit {{submitting ? 'btn-loading' : ''}}" bindtap="onSubmit">
          <text wx:if="{{!submitting}}">提交</text>
          <view wx:else class="loading-dots">
            <view class="dot"></view>
            <view class="dot"></view>
            <view class="dot"></view>
          </view>
        </view>
      </view>

      <!-- 爬取结果 -->
      <view class="card result-section" wx:if="{{results.length > 0}}">
        <view class="section-header">
          <text class="section-title">爬取结果</text>
          <text class="result-count">共 {{results.length}} 条</text>
        </view>
        <view class="result-grid">
          <view class="result-item" wx:for="{{results}}" wx:key="id">
            <image class="result-image" src="{{item.url}}" mode="aspectFill" lazy-load />
            <view class="result-overlay">
              <text class="result-title">{{item.title}}</text>
              <view class="result-stats">
                <text class="stat">❤ {{item.likes}}</text>
                <text class="stat">⭐ {{item.saves}}</text>
              </view>
            </view>
            <view class="result-check {{item.selected ? 'checked' : ''}}" bindtap="toggleSelect" data-id="{{item.id}}">
              <text wx:if="{{item.selected}}">✓</text>
            </view>
          </view>
        </view>
        <view class="btn btn-primary" bindtap="importSelected" wx:if="{{selectedCount > 0}}">
          导入选中素材 ({{selectedCount}})
        </view>
      </view>

      <!-- 空状态 -->
      <view class="empty-state" wx:if="{{showEmpty}}">
        <view class="empty-icon">🔍</view>
        <text>输入查询词开始爬取 Pinterest 素材</text>
      </view>
    </view>
  </scroll-view>
</view>
